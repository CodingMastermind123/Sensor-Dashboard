# Copy this file to backend/.env (for backend vars) and frontend/.env (for frontend vars).
# Real .env / .env.local files are gitignored — this template stays checked in.

# --- backend/.env ---
PORT=8080                  # HTTP + WebSocket server port
SERIAL_SOURCE=mock         # mock | real — mock needs no hardware, real reads SERIAL_PATH
SERIAL_PATH=               # e.g. /dev/cu.usbmodemXXXX — only used when SERIAL_SOURCE=real
BAUD=115200                # must match Serial.begin(115200) in the Arduino sketch
FRAME_MS=50                # expected ms between sensor frames (20 Hz)

# --- frontend/.env ---
# Vite only reads vars prefixed with VITE_, and only from frontend/.env (not the repo root).
VITE_WS_URL=ws://localhost:8080   # WebSocket URL the dashboard connects to
